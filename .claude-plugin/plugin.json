{
  "name": "alexandria",
  "version": "1.0.0",
  "description": "Active context management for coding agents. Provides wiki search, ingest, lint, and initialization via MCP tools.",
  "skills": "./skills/",
  "mcpServers": {
    "alexandria": {
      "command": "bun",
      "args": ["${CLAUDE_PLUGIN_ROOT}/src/index.ts"],
      "env": {}
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun ${CLAUDE_PLUGIN_ROOT}/src/hooks/session-start.ts"
          }
        ]
      }
    ]
  }
}
